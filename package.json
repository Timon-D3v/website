    "multer": "^2.0.1",
    "mysql2": "^3.13.0",
    "node-mailjet": "^6.0.7",
    "os": "^0.1.2",
    "path": "^0.12.7",
    "poisson-disk-sampling": "^2.3.1",
    "rxjs": "~7.8.2",
