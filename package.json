{
  "name": "portfolio",
  "version": "2.3.1",
  "description": "This is the source code of my website www.timondev.com.",
  "homepage": "https://www.timondev.com",
  "author": "Timon Fiedler",
  "license": "MPL-2.0",
  "repository": {
    "type": "git",
